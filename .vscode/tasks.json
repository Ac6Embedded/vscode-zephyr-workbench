{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "compile",
			"type": "npm",
			"script": "compile",
			"group": "build"
		},
		{
			"label": "watch",
			"type": "npm",
			"script": "watch",
			"problemMatcher": {
				"pattern": {
					"regexp": "^(\\b\\B)$",
					"message": 1
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "\\[watch\\].*build started",
					"endsPattern": "\\[watch\\] initial build complete"
				}
			},
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			}
		},
		{
			"label": "build",
			"dependsOrder": "sequence",
			"dependsOn": [
				"compile",
				"watch"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}
